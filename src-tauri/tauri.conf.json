{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "打字小课堂",
  "version": "0.1.0",
  "identifier": "com.zhouzhih.typingbeginner",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "打字小课堂",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Education",
    "shortDescription": "小学生打字练习软件",
    "longDescription": "面向小学生打字初学者的循序渐进练习软件。"
  }
}
